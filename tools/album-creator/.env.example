# Copy to .env in this directory, or use a .env in the Blog repo root when running from there.
# https://developer.adobe.com/console — OAuth Web app credential (Lightroom partner APIs).

ADOBE_CLIENT_ID=
# Required for OAuth Web (confidential) clients — shown on the credential details page in Console.
ADOBE_CLIENT_SECRET=
# Optional. HMAC key for .NET GalleryMaker-compatible unique IDs.
HASH_KEY=hashbrown
# Required for export uploads to Azure Blob (container: photos).
AzureConnectionString=

# Used by export: parent path on your CDN for album folders (BaseURL = PHOTOS_BASE_URL + "/" + slug).
# PHOTOS_BASE_URL=https://photos.duncanmackenzie.net/images
# Or set full folder URL per export: ALBUM_BASE_URL=https://photos.example.net/images/mytrip
# Optional if your CDN host is not https://photos.duncanmackenzie.net/
# PHOTOS_CDN_ROOT=https://photos.duncanmackenzie.net/

# Optional headless caption generation when using --generate-captions.
CAPTION_PROVIDER=anthropic
# CAPTION_MODEL=claude-opus-4-1
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
